generator client {
  provider      = "prisma-client-js"
  previewFeatures = ["omitApi"]
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Supabase, connection pooling is handled by the pooler
  // Pool settings: max 4 connections for Session mode, 1-2 for serverless
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatarUrl String?
  favoriteDriversIds String[]
  favoriteTeamsIds   String[]
  predictions Prediction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prediction {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  raceId   String
  round    String
  raceName String
  p1       String
  p2       String
  p3       String
  // Filled in server-side once the race result is known.
  score    Int?
  actualP1 String?
  actualP2 String?
  actualP3 String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, raceId])
  @@index([raceId])
}

model Driver {
  id                Int      @id @default(autoincrement())
  driverId          String   @unique
  imgUrl            String
  teamId            String?
  nationality       String?
  nationalityImgUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Team {
  id          Int      @id @default(autoincrement())
  teamId      String   @unique
  teamImgUrl  String
  bolidImgUrl String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
